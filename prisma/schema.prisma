generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model NeonProject {
  neonProjectId String          @id @map("neon_project_id")
  name          String
  regionId      String?         @map("region_id")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  snapshots     UsageSnapshot[]

  @@map("neon_projects")
}

model UsageSnapshot {
  id                          String   @id @default(cuid())
  neonProjectId               String   @map("neon_project_id")
  snapshotDate                DateTime @db.Date @map("snapshot_date")
  computeUnitSeconds          BigInt?  @map("compute_unit_seconds")
  rootBranchBytesMonth        BigInt?  @map("root_branch_bytes_month")
  childBranchBytesMonth       BigInt?  @map("child_branch_bytes_month")
  instantRestoreBytesMonth    BigInt?  @map("instant_restore_bytes_month")
  publicNetworkTransferBytes  BigInt?  @map("public_network_transfer_bytes")
  privateNetworkTransferBytes BigInt?  @map("private_network_transfer_bytes")
  extraBranchesMonth          BigInt?  @map("extra_branches_month")

  project NeonProject @relation(fields: [neonProjectId], references: [neonProjectId], onDelete: Cascade)

  @@unique([neonProjectId, snapshotDate])
  @@index([snapshotDate])
  @@map("usage_snapshots")
}

model SyncRun {
  id           String    @id @default(cuid())
  startedAt    DateTime  @default(now()) @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  status       String
  errorMessage String?   @map("error_message") @db.Text
  rowsUpserted Int?      @map("rows_upserted")
  targetDate   DateTime  @db.Date @map("target_date")

  @@index([startedAt])
  @@map("sync_runs")
}

model VercelProject {
  vercelProjectId String   @id @map("vercel_project_id")
  name            String
  framework       String?
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("vercel_projects")
}

/// One row per calendar day per project (or team) per service.
/// chargeDate = UTC calendar date derived from ChargePeriodStart.
/// vercelProjectId = '' (empty string) for team-level charges (Pro plan, etc.)
///   — non-nullable to allow composite unique constraint with upsert.
model VercelDailyCharge {
  id              String   @id @default(cuid())
  chargeDate      DateTime @db.Date @map("charge_date")
  /// Empty string for team-level charges (Pro plan, Speed Insights, etc.).
  vercelProjectId String   @map("vercel_project_id")
  serviceName     String   @map("service_name")
  /// Cost bucket: "plan" | "build" | "function" | "bandwidth" | "other"
  serviceCategory String   @map("service_category")
  consumedQty     Decimal  @map("consumed_qty") @db.Decimal(24, 10)
  consumedUnit    String   @map("consumed_unit")
  billedCost      Decimal  @map("billed_cost") @db.Decimal(18, 8)
  effectiveCost   Decimal  @map("effective_cost") @db.Decimal(18, 8)

  @@unique([chargeDate, vercelProjectId, serviceName])
  @@index([chargeDate])
  @@index([vercelProjectId])
  @@map("vercel_daily_charges")
}

model VercelSyncRun {
  id           String    @id @default(cuid())
  startedAt    DateTime  @default(now()) @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  status       String
  errorMessage String?   @map("error_message") @db.Text
  rowsUpserted Int?      @map("rows_upserted")
  targetDate   DateTime  @db.Date @map("target_date")

  @@index([startedAt])
  @@map("vercel_sync_runs")
}
