generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model NeonProject {
  neonProjectId String          @id @map("neon_project_id")
  name          String
  regionId      String?         @map("region_id")
  /** Per-project USD threshold for Telegram spend alerts; null uses env default. */
  spendAlertThresholdUsd Decimal? @map("spend_alert_threshold_usd") @db.Decimal(12, 4)
  /**
   * Min further-spend step as % of this row’s limit for same-day Telegram escalations; null uses
   * org default from `SPEND_ALERT_ESCALATION_PERCENT_OF_THRESHOLD`.
   */
  spendAlertEscalationPercentOfThreshold Decimal? @map("spend_alert_escalation_percent_of_threshold") @db.Decimal(5, 2)
  updatedAt     DateTime        @updatedAt @map("updated_at")
  snapshots     UsageSnapshot[]
  spendAlerts   SpendAlertSent[]

  @@map("neon_projects")
}

model UsageSnapshot {
  id                          String   @id @default(cuid())
  neonProjectId               String   @map("neon_project_id")
  snapshotDate                DateTime @db.Date @map("snapshot_date")
  computeUnitSeconds          BigInt?  @map("compute_unit_seconds")
  rootBranchBytesMonth        BigInt?  @map("root_branch_bytes_month")
  childBranchBytesMonth       BigInt?  @map("child_branch_bytes_month")
  instantRestoreBytesMonth    BigInt?  @map("instant_restore_bytes_month")
  publicNetworkTransferBytes  BigInt?  @map("public_network_transfer_bytes")
  privateNetworkTransferBytes BigInt?  @map("private_network_transfer_bytes")
  extraBranchesMonth          BigInt?  @map("extra_branches_month")

  project NeonProject @relation(fields: [neonProjectId], references: [neonProjectId], onDelete: Cascade)

  @@unique([neonProjectId, snapshotDate])
  @@index([snapshotDate])
  @@map("usage_snapshots")
}

model SyncRun {
  id           String    @id @default(cuid())
  startedAt    DateTime  @default(now()) @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  status       String
  errorMessage String?   @map("error_message") @db.Text
  rowsUpserted Int?      @map("rows_upserted")
  targetDate   DateTime  @db.Date @map("target_date")

  @@index([startedAt])
  @@map("sync_runs")
}

/**
 * One row per project per UTC day: first threshold breach + anchor for escalation dedupe.
 * `spendUsd` / `thresholdUsd` reflect the first alert; `lastNotifiedSpendUsd` updates on each sent message.
 */
model SpendAlertSent {
  id                   String    @id @default(cuid())
  neonProjectId        String    @map("neon_project_id")
  snapshotDate         DateTime  @db.Date @map("snapshot_date")
  sentAt               DateTime  @default(now()) @map("sent_at")
  spendUsd             Decimal   @map("spend_usd") @db.Decimal(12, 4)
  thresholdUsd         Decimal   @map("threshold_usd") @db.Decimal(12, 4)
  /** Spend at last Telegram notification (first or latest escalation); null on legacy rows. */
  lastNotifiedSpendUsd Decimal?  @map("last_notified_spend_usd") @db.Decimal(12, 4)

  project NeonProject @relation(fields: [neonProjectId], references: [neonProjectId], onDelete: Cascade)

  @@unique([neonProjectId, snapshotDate])
  @@index([snapshotDate])
  @@map("spend_alert_sent")
}
