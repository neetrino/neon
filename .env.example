# ——— App ———
NODE_ENV="development"
APP_URL="http://localhost:3000"

# Postgres (Neon) — analytics DB for this dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Neon Console API (Organization → Settings → API keys)
NEON_API_KEY=""
# Organization ID (Console URL or API)
NEON_ORG_ID=""
NEON_PRICING_PLAN="launch"

# Vercel Cron: set in project env; Vercel sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# Optional: protect UI + /api/usage/* (omit both to disable gate locally)
# If DASHBOARD_PASSWORD is set, JWT_SECRET must be set (32+ chars) for session cookie signing.
DASHBOARD_PASSWORD=""
JWT_SECRET=""

# Telegram spend alerts (optional): notify when a project’s estimated cost for the last synced UTC day exceeds the threshold.
# Get chat_id from @userinfobot or your bot updates. Alerts run after cron / “Sync now”.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
# Default threshold in USD when a project has no per-project override (dashboard table).
TELEGRAM_SPEND_ALERT_DEFAULT_USD="1"